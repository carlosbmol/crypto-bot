# ══════════════════════════════════════════════════════════
# Crypto Bot — Host secrets
# ══════════════════════════════════════════════════════════
# 1. Copy this file to `.env` in the same directory.
# 2. Replace every placeholder with a real value.
# 3. NEVER commit `.env` to git (already listed in .gitignore).
# ══════════════════════════════════════════════════════════

# Telegram bot token — create a bot with @BotFather to obtain it.
# Retrieve your chat_id by sending a message to the bot and opening:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TG_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

# Shared secret between Pine Script and the Docker webhook.
# Must match docker/docker-compose.yml -> WEBHOOK_SECRET
# and pine/tradingview_alert.pine -> "secret":"..."
WEBHOOK_SECRET=change_this_to_a_strong_random_value
