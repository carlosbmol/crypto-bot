# ══════════════════════════════════════════════════════════════
# TradingView → MT5 Bridge — Docker environment variables
# ══════════════════════════════════════════════════════════════
# 1. Copy this file to docker/.env
# 2. Replace every placeholder with a real value.
# ══════════════════════════════════════════════════════════════

# ngrok auth token — obtain yours at:
#   https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# Shared secret with TradingView.
# Must match EXACTLY:
#   - /.env (repo root)            -> WEBHOOK_SECRET
#   - pine/tradingview_alert.pine  -> "secret":"..."
WEBHOOK_SECRET=change_this_to_a_strong_random_value
