// ══════════════════════════════════════════════════════════════════
// UT Bot Alerts — Webhook MT5
// Based on UT Bot Alert by HPotter / Yo_adriiiiaan
// ══════════════════════════════════════════════════════════════════
// SETUP:
// 1. Open TradingView → Pine Script Editor → paste → Add to chart
// 2. Create Alert → Condition: "UT Bot Buy" or "UT Bot Sell"
// 3. Notifications → Webhook URL: https://YOUR-NGROK-URL/webhook
// 4. Message: leave as default (the script generates the JSON payload automatically)
// ══════════════════════════════════════════════════════════════════

//@version=5
indicator("UT Bot Alerts — MT5 Webhook", overlay=true)

// ── Parameters ────────────────────────────────────────────────────
a  = input.int(1,    "Key Value (Sensitivity)",  minval=1)
c  = input.int(10,   "ATR Period",               minval=1)
h  = input.bool(false, "Use Heikin Ashi Candles")

// ── Source (Heikin Ashi optional) ─────────────────────────────────
src = h ? request.security(ticker.heikinashi(syminfo.tickerid), timeframe.period, close) : close

// ── ATR Trailing Stop ─────────────────────────────────────────────
xATR  = ta.atr(c)
nLoss = a * xATR

var float xATRTrailingStop = 0.0
xATRTrailingStop := src > nz(xATRTrailingStop[1], 0) and src[1] > nz(xATRTrailingStop[1], 0) ?
     math.max(nz(xATRTrailingStop[1]), src - nLoss) :
     src < nz(xATRTrailingStop[1], 0) and src[1] < nz(xATRTrailingStop[1], 0) ?
     math.min(nz(xATRTrailingStop[1]), src + nLoss) :
     src > nz(xATRTrailingStop[1], 0) ? src - nLoss : src + nLoss

// ── Position ──────────────────────────────────────────────────────
var int pos = 0
pos := src[1] < nz(xATRTrailingStop[1], 0) and src > nz(xATRTrailingStop[1], 0) ? 1 :
       src[1] > nz(xATRTrailingStop[1], 0) and src < nz(xATRTrailingStop[1], 0) ? -1 : nz(pos[1], 0)

// ── Signals ───────────────────────────────────────────────────────
buy_signal  = pos ==  1 and pos[1] == -1
sell_signal = pos == -1 and pos[1] ==  1

// ── Plot trailing stop ────────────────────────────────────────────
plot(xATRTrailingStop,
     color = pos == 1 ? color.green : color.red,
     linewidth = 2,
     title = "UT Bot Trailing Stop")

plotshape(buy_signal,  title="BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white, size=size.small)
plotshape(sell_signal, title="SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white, size=size.small)

// ── Alert JSON payload for webhook ────────────────────────────────
// {{ticker}} is automatically replaced by TradingView with the chart symbol.
//
// ⚠️  IMPORTANT — before saving this alert in TradingView, replace TU_WEBHOOK_SECRET
//                 with the actual value from your .env (WEBHOOK_SECRET variable).
//                 This file is committed to a public repo, so never hardcode
//                 your real secret here.
alertcondition(buy_signal,
     title   = "UT Bot Buy",
     message = '{"symbol":"{{ticker}}","action":"BUY","secret":"TU_WEBHOOK_SECRET","price":"{{close}}"}')

alertcondition(sell_signal,
     title   = "UT Bot Sell",
     message = '{"symbol":"{{ticker}}","action":"SELL","secret":"TU_WEBHOOK_SECRET","price":"{{close}}"}')
